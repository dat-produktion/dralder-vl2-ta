# Dr. Alder Diagnostic Agent — V7 Environment Variables
# Copy this file to .env.local for local development
# Set all these in Vercel dashboard: Project → Settings → Environment Variables

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper speech-to-text)
OPENAI_API_KEY=sk-...

# Hetzner Object Storage
# Find in Hetzner console: Storage → Object Storage → your bucket → Credentials
HETZNER_ACCESS_KEY_ID=
HETZNER_SECRET_ACCESS_KEY=
HETZNER_BUCKET_NAME=dralder-line2-kb
HETZNER_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_REGION=fsn1
